import tkinter as tk
from tkinter import ttk, messagebox

class GestorTareasApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Gestor de Tareas - Con Atajos de Teclado")
        self.root.geometry("600x500")
        self.root.configure(bg="#f0f0f0")
        
        # Lista para almacenar las tareas (texto, completada)
        self.tareas = []
        
        self.crear_interfaz()
        self.configurar_atajos_teclado()
        
    def crear_interfaz(self):
        # Frame principal
        main_frame = tk.Frame(self.root, bg="#f0f0f0")
        main_frame.pack(padx=20, pady=20, fill="both", expand=True)
        
        # Título
        titulo = tk.Label(main_frame, text="📋 Gestor de Tareas", 
                         font=("Helvetica", 18, "bold"), bg="#f0f0f0")
        titulo.pack(pady=(0, 15))
        
        # Frame para añadir tarea
        frame_entrada = tk.Frame(main_frame, bg="#f0f0f0")
        frame_entrada.pack(fill="x", pady=5)
        
        tk.Label(frame_entrada, text="Nueva tarea:", font=("Helvetica", 10), bg="#f0f0f0").pack(anchor="w")
        
        # Campo de entrada
        self.entrada = tk.Entry(frame_entrada, font=("Helvetica", 12), width=50)
        self.entrada.pack(fill="x", pady=5, ipady=8)
        self.entrada.focus()  # Enfocar al iniciar
        
        # Botones
        frame_botones = tk.Frame(main_frame, bg="#f0f0f0")
        frame_botones.pack(fill="x", pady=10)
        
        btn_anadir = tk.Button(frame_botones, text="Añadir Tarea", font=("Helvetica", 10, "bold"),
                              bg="#4CAF50", fg="white", padx=15, pady=8,
                              command=self.anadir_tarea)
        btn_anadir.pack(side="left", padx=5)
        
        btn_completar = tk.Button(frame_botones, text="Marcar como Completada", font=("Helvetica", 10),
                                 bg="#2196F3", fg="white", padx=15, pady=8,
                                 command=self.marcar_completada)
        btn_completar.pack(side="left", padx=5)
        
        btn_eliminar = tk.Button(frame_botones, text="Eliminar Tarea", font=("Helvetica", 10),
                                bg="#f44336", fg="white", padx=15, pady=8,
                                command=self.eliminar_tarea)
        btn_eliminar.pack(side="left", padx=5)
        
        # Lista de tareas (Treeview para mejor apariencia)
        frame_lista = tk.Frame(main_frame)
        frame_lista.pack(fill="both", expand=True, pady=10)
        
        # Treeview
        columnas = ("tarea", "estado")
        self.tree = ttk.Treeview(frame_lista, columns=columnas, show="headings", height=15)
        
        self.tree.heading("tarea", text="Tarea")
        self.tree.heading("estado", text="Estado")
        
        self.tree.column("tarea", width=400, anchor="w")
        self.tree.column("estado", width=100, anchor="center")
        
        # Scrollbar
        scrollbar = ttk.Scrollbar(frame_lista, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)
        
        self.tree.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        
        # Bind doble clic para marcar como completada
        self.tree.bind("<Double-1>", lambda e: self.marcar_completada())
        
        # Label de ayuda con atajos
        ayuda = tk.Label(main_frame, 
                        text="Atajos de teclado:\n"
                             "Enter → Añadir tarea | C → Completar | D o Supr → Eliminar | Esc → Salir",
                        font=("Helvetica", 9), bg="#f0f0f0", fg="#555555", justify="center")
        ayuda.pack(pady=10)
        
    def configurar_atajos_teclado(self):
        # Atajo para añadir tarea con Enter
        self.entrada.bind("<Return>", lambda e: self.anadir_tarea())
        
        # Atajos globales (en la ventana principal)
        self.root.bind("<c>", lambda e: self.marcar_completada())      # tecla C
        self.root.bind("<d>", lambda e: self.eliminar_tarea())         # tecla D
        self.root.bind("<Delete>", lambda e: self.eliminar_tarea())    # tecla Supr/Delete
        self.root.bind("<Escape>", lambda e: self.root.quit())         # tecla Escape
        
        # Para que los atajos funcionen incluso si hay un widget seleccionado
        self.root.bind_all("<c>", lambda e: self.marcar_completada())
        self.root.bind_all("<d>", lambda e: self.eliminar_tarea())
        self.root.bind_all("<Delete>", lambda e: self.eliminar_tarea())
        
    def anadir_tarea(self):
        texto = self.entrada.get().strip()
        
        if not texto:
            messagebox.showwarning("Advertencia", "Por favor escribe una tarea")
            return
        
        # Añadir a la lista interna
        self.tareas.append({"texto": texto, "completada": False})
        
        # Insertar en el Treeview
        self.tree.insert("", "end", values=(texto, "Pendiente"))
        
        # Limpiar entrada
        self.entrada.delete(0, tk.END)
        self.entrada.focus()
        
    def marcar_completada(self):
        seleccion = self.tree.selection()
        if not seleccion:
            messagebox.showwarning("Advertencia", "Selecciona una tarea para marcar como completada")
            return
        
        item = seleccion[0]
        indice = self.tree.index(item)
        
        # Cambiar estado
        self.tareas[indice]["completada"] = True
        
        # Actualizar Treeview
        texto = self.tareas[indice]["texto"]
        self.tree.item(item, values=(texto, "✅ Completada"))
        
        # Opcional: cambiar color de la fila
        self.tree.tag_configure("completada", foreground="gray")
        self.tree.item(item, tags=("completada",))
        
    def eliminar_tarea(self):
        seleccion = self.tree.selection()
        if not seleccion:
            messagebox.showwarning("Advertencia", "Selecciona una tarea para eliminar")
            return
        
        if messagebox.askyesno("Confirmar", "¿Estás seguro de eliminar esta tarea?"):
            item = seleccion[0]
            indice = self.tree.index(item)
            
            # Eliminar de la lista interna y del Treeview
            del self.tareas[indice]
            self.tree.delete(item)
    
    def run(self):
        self.root.mainloop()


# ====================== EJECUCIÓN ======================
if __name__ == "__main__":
    root = tk.Tk()
    app = GestorTareasApp(root)
    app.run()
