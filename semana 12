class Libro:
    def __init__(self, titulo, autor, categoria, isbn):
        # Usar tupla para atributos inmutables: título y autor
        self.info = (titulo, autor)
        self.categoria = categoria
        self.isbn = isbn

    @property
    def titulo(self):
        return self.info[0]

    @property
    def autor(self):
        return self.info[1]

    def __str__(self):
        return f"{self.titulo} por {self.autor} (ISBN: {self.isbn}, Categoría: {self.categoria})"

class Usuario:
    def __init__(self, nombre, id_usuario):
        self.nombre = nombre
        self.id_usuario = id_usuario
        self.libros_prestados = []  # Lista de objetos Libro prestados

    def __str__(self):
        return f"Usuario: {self.nombre} (ID: {self.id_usuario})"

class Biblioteca:
    def __init__(self):
        self.libros = {}  # Diccionario: ISBN -> Libro (libros disponibles)
        self.usuarios = {}  # Diccionario: id_usuario -> Usuario
        self.usuarios_ids = set()  # Conjunto para IDs únicos

    def añadir_libro(self, libro):
        if libro.isbn in self.libros:
            print(f"El libro con ISBN {libro.isbn} ya existe en la biblioteca.")
            return
        self.libros[libro.isbn] = libro
        print(f"Libro añadido: {libro}")

    def quitar_libro(self, isbn):
        if isbn not in self.libros:
            print(f"No se encontró el libro con ISBN {isbn}.")
            return
        libro = self.libros.pop(isbn)
        print(f"Libro quitado: {libro}")

    def registrar_usuario(self, usuario):
        if usuario.id_usuario in self.usuarios_ids:
            print(f"El ID de usuario {usuario.id_usuario} ya está registrado.")
            return
        self.usuarios[usuario.id_usuario] = usuario
        self.usuarios_ids.add(usuario.id_usuario)
        print(f"Usuario registrado: {usuario}")

    def dar_baja_usuario(self, id_usuario):
        if id_usuario not in self.usuarios_ids:
            print(f"No se encontró el usuario con ID {id_usuario}.")
            return
        usuario = self.usuarios.pop(id_usuario)
        self.usuarios_ids.remove(id_usuario)
        # Devolver cualquier libro prestado
        for libro in usuario.libros_prestados:
            self.libros[libro.isbn] = libro
        usuario.libros_prestados.clear()
        print(f"Usuario dado de baja: {usuario}")

    def prestar_libro(self, isbn, id_usuario):
        if id_usuario not in self.usuarios_ids:
            print(f"No se encontró el usuario con ID {id_usuario}.")
            return
        if isbn not in self.libros:
            print(f"El libro con ISBN {isbn} no está disponible.")
            return
        libro = self.libros.pop(isbn)
        usuario = self.usuarios[id_usuario]
        usuario.libros_prestados.append(libro)
        print(f"Libro prestado: {libro} a {usuario}")

    def devolver_libro(self, isbn, id_usuario):
        if id_usuario not in self.usuarios_ids:
            print(f"No se encontró el usuario con ID {id_usuario}.")
            return
        usuario = self.usuarios[id_usuario]
        for i, libro in enumerate(usuario.libros_prestados):
            if libro.isbn == isbn:
                devuelto = usuario.libros_prestados.pop(i)
                self.libros[isbn] = devuelto
                print(f"Libro devuelto: {devuelto} por {usuario}")
                return
        print(f"El usuario no tiene el libro con ISBN {isbn} prestado.")

    def buscar_libros(self, por, valor):
        resultados = []
        for libro in self.libros.values():
            if por.lower() == 'titulo' and libro.titulo.lower() == valor.lower():
                resultados.append(libro)
            elif por.lower() == 'autor' and libro.autor.lower() == valor.lower():
                resultados.append(libro)
            elif por.lower() == 'categoria' and libro.categoria.lower() == valor.lower():
                resultados.append(libro)
        return resultados

    def listar_libros_prestados(self, id_usuario):
        if id_usuario not in self.usuarios_ids:
            print(f"No se encontró el usuario con ID {id_usuario}.")
            return []
        usuario = self.usuarios[id_usuario]
        return usuario.libros_prestados
